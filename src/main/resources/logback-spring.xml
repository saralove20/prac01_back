<configuration>
  <!-- 콘솔창 로그 색깔 넣는 라이브러리 -->
  <conversionRule conversionWord="clr"
                  converterClass="org.springframework.boot.logging.logback.ColorConverter"/>

  <!-- 콘솔에 출력 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <!-- 출력 형식 지정 -->
      <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss}){faint} %clr([%thread]){faint} %clr(%-5level) %clr(%logger{36}){cyan} - %msg%n</pattern>
    </encoder>
</appender>

  <!-- 프로젝트 내 로그 파일에 출력 -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>logs/spring-application.log</file> <!-- 로그 파일 경로 설정 -->
    <!-- 시간 별로 쪼개서 저장할 수 있도록 롤링 파일 설정 -->
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>logs/spring-application.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>30</maxHistory> <!-- 최대 30개 가지의 파일을 남기도록 설정 -->
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- 리눅스 서버 (중앙 로그 서버) 로그 파일에 출력 -->
  <appender name="SYSLOG" class="ch.qos.logback.classic.net.SyslogAppender">
    <syslogHost>192.168.100.101</syslogHost> <!-- 로그 서버 IP 주소 -->
    <port>514</port>
    <facility>USER</facility>
    <suffixPattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %m%n</suffixPattern>
  </appender>

  <root level="info">
    <appender-ref ref="CONSOLE" />
    <appender-ref ref="FILE" />
    <appender-ref ref="SYSLOG" />
  </root>
</configuration>